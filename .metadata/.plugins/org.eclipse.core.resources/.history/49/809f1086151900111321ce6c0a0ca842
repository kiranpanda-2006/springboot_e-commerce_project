<!DOCTYPE html>
<html lang="en" xmlns:th="http://www.thymeleaf.org"
	th:replace="~{base::layout(~{::section})}">
<head>
<meta charset="ISO-8859-1">
<title>Ecom Store</title>
</head>
<body>
	<section>
		<div class="container hero">
			<div class="row g-4 align-items-center hero-card p-4 p-lg-5">
				<div class="col-lg-6">
					<div class="hero-badge mb-3"><i class="fa-solid fa-bolt"></i> Fast delivery • Secure checkout • Easy returns</div>
					<h1 class="display-6 fw-bold mb-3">Shop smarter with <span class="text-info">Ecom Store</span></h1>
					<p class="mb-4">Browse categories, discover deals, and order in minutes. Your cart, orders, and profile are always one click away.</p>
					<div class="d-flex gap-2 flex-wrap">
						<a href="/products" class="btn btn-primary btn-lg"><i class="fa-solid fa-bag-shopping me-2"></i>Explore products</a>
						<a href="#cats" class="btn btn-outline-light btn-lg"><i class="fa-solid fa-layer-group me-2"></i>Browse categories</a>
					</div>
				</div>
				<div class="col-lg-6">
					<div id="carouselExample" class="carousel slide rounded-4 overflow-hidden" data-bs-ride="carousel">
						<div class="carousel-inner">
							<div class="carousel-item active">
								<img src="img/ecom1.png" class="d-block w-100" alt="Banner" height="360px">
							</div>
							<div class="carousel-item">
								<img src="img/ecom3.jpg" class="d-block w-100" alt="Banner" height="360px">
							</div>
							<div class="carousel-item">
								<img src="img/ecom2.jpg" class="d-block w-100" alt="Banner" height="360px">
							</div>
						</div>
						<button class="carousel-control-prev" type="button" data-bs-target="#carouselExample" data-bs-slide="prev">
							<span class="carousel-control-prev-icon" aria-hidden="true"></span>
							<span class="visually-hidden">Previous</span>
						</button>
						<button class="carousel-control-next" type="button" data-bs-target="#carouselExample" data-bs-slide="next">
							<span class="carousel-control-next-icon" aria-hidden="true"></span>
							<span class="visually-hidden">Next</span>
						</button>
					</div>
				</div>
			</div>
		</div>

		<div class="container page-pad" id="cats">
			<div class="section-title">
				<h2 class="fw-semibold">Shop by category</h2>
				<div class="hint">Tap a category to filter products</div>
			</div>
			<div class="row g-3">
				<div class="col-6 col-md-4 col-lg-3" th:each="c:${category}">
					<a class="category-chip" th:href="@{'/products?category='+${c.name}}">
						<img th:src="@{'img/category_img/'+${c.imageName}}" alt="Category">
						<div>
							<div class="fw-semibold">[[${c.name}]]</div>
							<div class="small" style="color: var(--app-muted);">Browse items</div>
						</div>
					</a>
				</div>
			</div>

			<div class="section-title mt-5">
				<h2 class="fw-semibold">Latest products</h2>
				<a href="/products" class="btn btn-sm btn-outline-light">View all</a>
			</div>

			<div class="row g-3">
				<div class="col-12 col-sm-6 col-lg-3" th:each="p:${products}">
					<div class="product-card">
						<div class="img-wrap">
							<img th:src="@{'img/product_img/'+${p.image}}" alt="Product">
						</div>
						<div class="p-3">
							<a class="title" th:href="@{'/product/'+${p.id}}">[[${p.title}]]</a>
							<div class="d-flex justify-content-between align-items-center mt-3">
								<a class="btn btn-primary btn-sm" th:href="@{'/product/'+${p.id}}"><i class="fa-solid fa-eye me-2"></i>View</a>
								<span class="small" style="color: var(--app-muted);">New arrival</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
</body>
</html>
