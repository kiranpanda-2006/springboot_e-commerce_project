@charset "UTF-8";

:root {
	--app-bg: #0b1220;
	--app-surface: rgba(255, 255, 255, 0.08);
	--app-border: rgba(255, 255, 255, 0.12);
	--app-text: rgba(255, 255, 255, 0.92);
	--app-muted: rgba(255, 255, 255, 0.68);
}

/* Global */
.app-body {
	min-height: 100vh;
	background: radial-gradient(1200px 600px at 10% 10%, rgba(99, 102, 241, .35), transparent 60%),
				radial-gradient(900px 500px at 90% 20%, rgba(16, 185, 129, .25), transparent 55%),
				linear-gradient(180deg, #050914 0%, var(--app-bg) 55%, #050914 100%);
	color: var(--app-text);
}

.app-main {
	padding-top: 84px; /* fixed navbar */
	min-height: calc(100vh - 84px);
}

.page-pad {
	padding-top: 32px;
	padding-bottom: 64px;
}

/* Navbar */
.navbar-glass {
	background: rgba(5, 9, 20, 0.65) !important;
	backdrop-filter: blur(14px);
	border-bottom: 1px solid rgba(255, 255, 255, 0.10);
}

.navbar-glass .nav-link {
	opacity: 0.9;
}

.navbar-glass .nav-link:hover {
	opacity: 1;
}

/* Cards */
.glass-card {
	background: var(--app-surface);
	border: 1px solid var(--app-border);
	border-radius: 18px;
}

.card-sh {
	box-shadow: 0 12px 30px rgba(0, 0, 0, 0.35);
}

.cat-div {
	box-shadow: 0 10px 24px rgba(0, 0, 0, .18);
}

/* Forms */
.form-control, .form-select {
	border-radius: 12px;
}

.btn {
	border-radius: 12px;
}

.btn-primary {
	box-shadow: 0 10px 22px rgba(13, 110, 253, 0.25);
}

/* Footer */
.app-footer {
	border-top: 1px solid rgba(255, 255, 255, 0.10);
	background: rgba(5, 9, 20, 0.50);
	backdrop-filter: blur(10px);
}

/* Validation */
.error {
	color: #ff6b6b;
}

/* Make Bootstrap light surfaces readable on dark background */
.bg-light, .bg-body-tertiary, .bg-white {
	background-color: rgba(255, 255, 255, 0.92) !important;
}

@media (max-width: 576px) {
	.app-main { padding-top: 76px; }
	.page-pad { padding-top: 20px; }
}

/* ---------- Modern UI components ---------- */
.hero {
	padding: 42px 0 18px;
}
.hero .hero-card{
	background: rgba(255,255,255,.06);
	border: 1px solid rgba(255,255,255,.12);
	border-radius: 22px;
	box-shadow: 0 18px 44px rgba(0,0,0,.35);
	overflow: hidden;
}
.hero .hero-badge{
	display:inline-flex;
	align-items:center;
	gap:10px;
	padding: 8px 12px;
	border-radius: 999px;
	background: rgba(255,255,255,.10);
	border: 1px solid rgba(255,255,255,.14);
	color: var(--app-text);
	font-size: 0.9rem;
}
.hero h1{
	letter-spacing: -0.6px;
}
.hero p{
	color: var(--app-muted);
}

.section-title{
	display:flex;
	align-items:flex-end;
	justify-content:space-between;
	gap: 16px;
	margin: 18px 0 14px;
}
.section-title h2{
	font-size: 1.25rem;
	margin: 0;
}
.section-title .hint{
	color: var(--app-muted);
	font-size: 0.95rem;
}

.category-chip{
	display:flex;
	align-items:center;
	gap: 12px;
	padding: 10px 12px;
	border-radius: 16px;
	background: rgba(255,255,255,.06);
	border: 1px solid rgba(255,255,255,.12);
	text-decoration:none;
	color: var(--app-text);
	transition: transform .15s ease, background .15s ease, border-color .15s ease;
}
.category-chip:hover{
	transform: translateY(-2px);
	background: rgba(255,255,255,.08);
	border-color: rgba(255,255,255,.18);
	color: var(--app-text);
}
.category-chip img{
	width: 44px;
	height: 44px;
	object-fit: cover;
	border-radius: 12px;
}

.product-card{
	background: rgba(255,255,255,.06);
	border: 1px solid rgba(255,255,255,.12);
	border-radius: 18px;
	overflow:hidden;
	height: 100%;
	transition: transform .15s ease, box-shadow .15s ease, border-color .15s ease;
}
.product-card:hover{
	transform: translateY(-3px);
	border-color: rgba(255,255,255,.20);
	box-shadow: 0 18px 40px rgba(0,0,0,.40);
}
.product-card .img-wrap{
	background: rgba(255,255,255,.04);
	border-bottom: 1px solid rgba(255,255,255,.10);
	display:flex;
	align-items:center;
	justify-content:center;
	padding: 14px;
}
.product-card img{
	width: 100%;
	max-width: 220px;
	height: 170px;
	object-fit: contain;
}
.product-card .title{
	color: var(--app-text);
	text-decoration:none;
	font-weight: 600;
	display:block;
	line-height: 1.25;
}
.product-card .title:hover{
	text-decoration: underline;
}
.price-row{
	display:flex;
	align-items:baseline;
	gap: 10px;
	flex-wrap: wrap;
}
.price-now{
	font-weight: 800;
}
.price-old{
	color: rgba(255,255,255,.55);
	text-decoration: line-through;
}
.badge-off{
	background: rgba(16,185,129,.18);
	border: 1px solid rgba(16,185,129,.35);
	color: #b9ffe5;
}

.search-bar{
	background: rgba(255,255,255,.06);
	border: 1px solid rgba(255,255,255,.12);
	border-radius: 18px;
	padding: 14px;
}

.sidebar-card{
	position: sticky;
	top: 92px;
	background: rgba(255,255,255,.06);
	border: 1px solid rgba(255,255,255,.12);
	border-radius: 18px;
}

.toast.app-toast{
	backdrop-filter: blur(12px);
	box-shadow: 0 18px 40px rgba(0,0,0,.40);
	border-radius: 14px;
}

.table, .pagination .page-link{
	border-radius: 12px;
}

/* Improve bootstrap "bg-light" sections on dark background */
.surface-light{
	background: rgba(255,255,255,.92);
	border-radius: 18px;
}


.admin-hero{
	background: linear-gradient(135deg, rgba(13,110,253,.20), rgba(111,66,193,.20));
	border: 1px solid rgba(255,255,255,.12);
	border-radius: 24px;
	box-shadow: 0 20px 50px rgba(0,0,0,.35);
}
.pill-tag{
	padding: 8px 14px;
	border-radius: 999px;
	background: rgba(255,255,255,.10);
	border: 1px solid rgba(255,255,255,.16);
}
.metric-card{
	background: rgba(255,255,255,.08);
	border: 1px solid rgba(255,255,255,.12);
	border-radius: 18px;
	padding: 18px;
	height: 100%;
}
.metric-label{ color: var(--app-muted); font-size:.9rem; }
.metric-value{ font-size: 1.8rem; font-weight: 800; }
.admin-action-card{
	display:flex;
	gap:16px;
	align-items:flex-start;
	background: rgba(255,255,255,.06);
	border: 1px solid rgba(255,255,255,.12);
	border-radius: 20px;
	padding: 20px;
	height:100%;
	color: var(--app-text);
	transition: transform .15s ease, box-shadow .15s ease;
}
.admin-action-card:hover{ transform: translateY(-4px); box-shadow: 0 18px 42px rgba(0,0,0,.35); color: var(--app-text); }
.admin-action-card .icon{
	width:52px; height:52px; display:grid; place-items:center; border-radius:16px;
	background: rgba(13,110,253,.18); font-size:1.3rem;
}
.admin-action-card h5{ margin:0 0 6px; }
.admin-action-card p{ margin:0; color: var(--app-muted); }
.modern-table{ --bs-table-bg: transparent; --bs-table-striped-bg: rgba(255,255,255,.03); --bs-table-hover-bg: rgba(255,255,255,.05); }
.table-thumb{ width:56px; height:56px; object-fit:cover; border-radius:14px; border:1px solid rgba(255,255,255,.12); }
.checkout-card{ border-radius: 22px; }
.checkout-heading{ font-size:1.1rem; font-weight:700; margin-bottom:16px; }
.summary-row{ display:flex; justify-content:space-between; align-items:center; padding:10px 0; border-bottom:1px solid rgba(255,255,255,.08); }
.summary-row.total{ border-bottom:0; padding-top:14px; font-size:1.05rem; }
.payment-grid{ display:grid; gap:12px; }
.payment-option{ position:relative; display:block; cursor:pointer; }
.payment-option input{ position:absolute; opacity:0; }
.payment-option span{ display:flex; align-items:center; padding:14px 16px; border-radius:16px; border:1px solid rgba(255,255,255,.12); background:rgba(255,255,255,.05); }
.payment-option input:checked + span{ border-color: rgba(13,110,253,.6); background: rgba(13,110,253,.14); box-shadow: inset 0 0 0 1px rgba(13,110,253,.35); }
.payment-option.disabled{ opacity:.55; cursor:not-allowed; }
.code{ word-break: break-word; }
